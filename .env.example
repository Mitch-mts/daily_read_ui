# Public app URL (used for absolute links in metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: override the upstream Bible text provider (defaults to bible-api.com)
BIBLE_API_BASE_URL=https://bible-api.com

# Optional: Bible translation passed to the provider (e.g. kjv, web)
BIBLE_TRANSLATION=

# Reserved for future persistence (favorites, reading history)
# DATABASE_URL=

# Reserved for future AI features (reflection prompts, study guides)
# OPENAI_API_KEY=
